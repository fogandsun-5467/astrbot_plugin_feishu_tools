{
  "enabled_tools": {
    "description": "启用的工具列表",
    "type": "list",
    "default": ["message", "chat", "doc", "drive", "task", "bitable", "calendar", "sheets", "wiki", "reaction", "urgent"],
    "hint": "选择要启用的飞书工具，未启用的工具将不会注册到 LLM"
  },
  "message_tool": {
    "description": "消息工具配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用消息工具",
        "type": "bool",
        "default": true
      },
      "max_list_size": {
        "description": "消息列表最大返回数量",
        "type": "int",
        "default": 50,
        "hint": "获取消息列表时的最大返回数量，范围1-50"
      }
    }
  },
  "doc_tool": {
    "description": "文档工具配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用文档工具",
        "type": "bool",
        "default": true
      },
      "max_media_size_mb": {
        "description": "最大媒体文件大小(MB)",
        "type": "int",
        "default": 20,
        "hint": "文档中嵌入的图片等媒体文件的最大大小"
      }
    }
  },
  "task_tool": {
    "description": "任务工具配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用任务工具",
        "type": "bool",
        "default": true
      },
      "default_assign_self": {
        "description": "默认将任务分配给请求者",
        "type": "bool",
        "default": true,
        "hint": "创建任务时如果没有指定负责人，是否默认分配给请求者"
      }
    }
  },
  "bitable_tool": {
    "description": "多维表格工具配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用多维表格工具",
        "type": "bool",
        "default": true
      }
    }
  },
  "calendar_tool": {
    "description": "日历工具配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用日历工具",
        "type": "bool",
        "default": true
      }
    }
  },
  "sheets_tool": {
    "description": "电子表格工具配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用电子表格工具",
        "type": "bool",
        "default": true
      }
    }
  },
  "perm_tool": {
    "description": "权限工具配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用权限工具",
        "type": "bool",
        "default": false,
        "hint": "权限管理是敏感操作，默认禁用"
      }
    }
  },
  "urgent_tool": {
    "description": "紧急通知工具配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用紧急通知工具",
        "type": "bool",
        "default": true
      },
      "default_type": {
        "description": "默认紧急通知类型",
        "type": "string",
        "default": "app",
        "options": ["app", "sms", "phone"],
        "hint": "app: 应用内通知(免费), sms: 短信通知(可能收费), phone: 电话通知(可能收费)"
      }
    }
  }
}
